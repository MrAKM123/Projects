# ==========================================
# UNIVERSAL GITIGNORE FOR MULTIPLE PROJECTS
# ==========================================

# Automatically ignores node_modules in any current or future project folder
**/node_modules/

# Automatically ignores environment configuration files anywhere (security)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Ignores frontend production build outputs
**/build/
**/dist/
**/.next/

# Debug logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System-specific files
.DS_Store
Thumbs.db